# ============================================
# Application
# ============================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================
# Supabase Configuration
# ============================================
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ============================================
# Resend Email Configuration
# ============================================
RESEND_API_KEY="re_your-resend-api-key"
RESEND_FROM_EMAIL="Think5 <noreply@yourdomain.com>"

# ============================================
# Database — Supabase Postgres + PgBouncer
# ============================================
# DATABASE_URL: Use the Supabase POOLER endpoint (port 6543) for all
# application queries. PgBouncer (transaction mode) aggregates connections
# across serverless function instances so each instance only needs a
# small pool (default 5 via PRISMA_CONNECTION_LIMIT).
#
# DIRECT_URL: Non-pooler endpoint (port 5432) used ONLY by Prisma Migrate.
# PgBouncer breaks prepared statements in migration mode, so migrations
# must go direct.
#
# In production, set these in the Vercel environment, NOT in .env.
DATABASE_URL="postgresql://user:password@db.your-project.supabase.co:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://user:password@db.your-project.supabase.co:5432/postgres"

# Per-instance connection pool size. Default 5 with PgBouncer is optimal.
# Only raise if you see "pool_timeout" errors in Prisma logs AND the
# Supabase dashboard shows headroom on the backend connection count.
# PRISMA_CONNECTION_LIMIT=5

# ============================================
# OpenAI API
# ============================================
OPENAI_API_KEY="your-openai-api-key-here"

# ============================================
# JWT Secret (Legacy - use Supabase Auth instead)
# ============================================
JWT_SECRET="your-jwt-secret-key-here"

# ============================================
# Gemini AI (Aria Interview System)
# ============================================
GEMINI_API_KEY="your-gemini-api-key-here"

# ============================================
# Voice Relay (WebSocket proxy for Gemini Live)
# Deploy relay/server.ts to Fly.io, then set URL here.
# RELAY_JWT_SECRET must match between app and relay.
# ============================================
VOICE_RELAY_URL="wss://your-relay.fly.dev"
RELAY_JWT_SECRET="your-relay-jwt-secret-here"

# ============================================
# File Storage
# ============================================
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=10485760

# ============================================
# PII Encryption (Field-level AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ============================================
PII_ENCRYPTION_KEY="your-64-character-hex-key-here"

# ============================================
# Secrets Vault (optional — for production)
# SECRETS_PROVIDER: "env" (default) | "aws" | "vault"
# ============================================
# SECRETS_PROVIDER="env"
# AWS_SECRET_ARN="arn:aws:secretsmanager:us-east-1:123456789:secret:paraform-prod"
# AWS_REGION="us-east-1"
# VAULT_ADDR="https://vault.yourdomain.com"
# VAULT_TOKEN="your-vault-token"
# VAULT_SECRET_PATH="secret/data/paraform"
