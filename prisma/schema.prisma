// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Connection pooling: Handled by PgBouncer via DATABASE_URL (Supabase pooler).
// DIRECT_URL bypasses pooler for migrations. See: https://www.prisma.io/docs/orm/prisma-client/setup-and-configuration/databases-connections/pgbouncer
datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================
// Enums
// ============================================

enum CandidateStatus {
  SOURCED
  CONTACTED
  INTERVIEWED
  OFFERED
  HIRED
  REJECTED
}

enum InterviewStatus {
  CREATED
  PLAN_GENERATED
  PENDING
  IN_PROGRESS
  PAUSED
  DISCONNECTED
  COMPLETED
  CANCELLED
  EXPIRED
  REPORT_GENERATING
  REPORT_READY
  REPORT_FAILED
}

enum InterviewType {
  TECHNICAL
  BEHAVIORAL
  DOMAIN_EXPERT
  LANGUAGE
  CASE_STUDY
}

enum InterviewMode {
  GENERAL_PROFILE
  JOB_FIT
  HYBRID
  CULTURAL_FIT
  TECHNICAL_DEEP_DIVE
  SCREENING
  CUSTOM
}

enum RecordingState {
  UPLOADING
  FINALIZING
  COMPLETE
  VERIFIED
  DELETED
}

enum TemplateStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  ARCHIVED
}

enum EvidenceConfidence {
  HIGH
  MEDIUM
  LOW
}

enum JobStatus {
  DRAFT
  ACTIVE
  PAUSED
  CLOSED
  FILLED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  TEMP_TO_HIRE
}

enum RemoteType {
  REMOTE
  ONSITE
  HYBRID
}

enum ApplicationStatus {
  APPLIED
  SCREENING
  INTERVIEWING
  SHORTLISTED
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN
}

enum InvitationStatus {
  CREATED
  PENDING
  SENT
  DELIVERED
  OPENED
  ACCEPTED
  EXPIRED
  REVOKED
  DECLINED
  INTERVIEW_STARTED
  INTERVIEW_COMPLETED
  ABANDONED
}

enum NotificationType {
  INTERVIEW_INVITE
  APPLICATION_UPDATE
  MATCH_ALERT
  FEEDBACK_READY
  SYSTEM
}

enum SkillImportance {
  REQUIRED
  PREFERRED
  NICE_TO_HAVE
}

enum PassiveProfileStatus {
  CREATED
  INVITED
  LINKED
  EXPIRED
}

enum DocumentType {
  RESUME
  COVER_LETTER
  CERTIFICATION
  OTHER
}

enum ProctoringEventSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ReviewStatus {
  PENDING_REVIEW
  REVIEWED
  OVERRIDDEN
}

enum ReviewDecisionType {
  APPROVE
  REJECT
  FLAG
  OVERRIDE
}

enum RemotePreference {
  REMOTE
  HYBRID
  ONSITE
  FLEXIBLE
}

enum CandidateAvailability {
  IMMEDIATELY
  TWO_WEEKS
  ONE_MONTH
  THREE_MONTHS
  NOT_LOOKING
}

enum OnboardingStatus {
  INVITED
  PROFILE_STARTED
  PROFILE_COMPLETED
  PENDING_APPROVAL
  APPROVED
  REJECTED
  ON_HOLD
}

enum RecruiterOnboardingStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

// ============================================
// Core Models
// ============================================

model Recruiter {
  id              String      @id @default(uuid())
  supabaseUserId  String?     @unique
  name            String
  email           String      @unique
  phone           String?
  title           String?
  department      String?
  companyId       String?
  company         Client?     @relation(fields: [companyId], references: [id])

  // Onboarding tracking
  onboardingStep        Int                        @default(0)
  onboardingCompleted   Boolean                    @default(false)
  onboardingStatus      RecruiterOnboardingStatus  @default(NOT_STARTED)
  linkedinUrl           String?
  profileImage          String?
  bio                   String?                    @db.Text
  hiringPreferences     Json?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  candidates            Candidate[]
  interviews            Interview[]            @relation("ScheduledByRecruiter")
  jobs                  Job[]
  interviewTemplates    InterviewTemplate[]
  interviewInvitations  InterviewInvitation[]
  passiveProfiles       PassiveProfile[]
  skillModules          SkillModule[]

  @@index([companyId])
  @@index([onboardingStatus])
}

model Candidate {
  id               String          @id @default(uuid())
  fullName         String
  email            String?
  phone            String?
  linkedinUrl      String?
  profileImage     String?
  currentTitle     String?
  currentCompany   String?
  skills           Json            @default("[]")
  experienceYears  Int?
  industries       Json            @default("[]")
  resumeText       String?         @db.Text
  resumeUrl        String?
  status           CandidateStatus @default(SOURCED)
  recruiterId      String
  recruiter        Recruiter       @relation(fields: [recruiterId], references: [id], onDelete: Cascade)
  embedding        Json?
  aiSummary        String?         @db.Text
  experiences      Json?
  education        Json?
  headline         String?
  location         String?
  notes            Note[]
  matches          Match[]
  interviews       Interview[]

  // Aria interview flags
  ariaInterviewed  Boolean         @default(false)
  ariaOverallScore Float?

  // Onboarding tracking
  onboardingCompleted   Boolean          @default(false)
  onboardingStep        Int              @default(0)
  onboardingStatus      OnboardingStatus @default(PROFILE_STARTED)
  approvedAt            DateTime?
  approvedBy            String?
  rejectionReason       String?
  invitationSource      String?          // "self_signup" | "recruiter_invited"
  profileCompleteness   Float?

  // Quality signals (admin approval intelligence)
  riskScore               Float?
  riskFlags               Json?           // [{type, severity, message}]
  linkedinConsistencyScore Float?         // 0-100
  linkedinConsistencyFlags Json?          // [{field, resumeValue, linkedinValue, severity}]

  // Bias audit (AEDT compliance)
  demographicData         Json?           // Self-reported, optional
  demographicConsentGiven Boolean         @default(false)

  // Candidate preferences & compliance
  visaStatus            String?
  preferredTitles       String[]         @default([])
  consentGdpr           Boolean          @default(false)
  consentDataProcessing Boolean          @default(false)
  consentedAt           DateTime?

  // Legal hold — prevents retention enforcement from deleting data
  legalHold             Boolean          @default(false)
  legalHoldReason       String?

  // New relations
  applications          Application[]
  invitations           InterviewInvitation[]
  documents             Document[]
  candidateSkills       CandidateSkill[]
  candidateExperiences  CandidateExperience[]
  candidateEducation    CandidateEducation[]
  certifications        CandidateCertification[]
  notifications         Notification[]
  jobPreferences        JobPreference?
  approvalActions       ApprovalAction[]
  deletionRequests      DataDeletionRequest[]

  // Embedding freshness tracking
  embeddingUpdatedAt DateTime?

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([recruiterId])
  @@index([status])
  @@index([ariaInterviewed])
  @@index([email])
  @@index([onboardingStatus])
  @@unique([email, recruiterId])
}

model Note {
  id              String    @id @default(uuid())
  content         String    @db.Text
  isPrivate       Boolean   @default(true)
  candidateId     String
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  authorId        String

  // Activity tracking fields
  callAnswered    Boolean?
  voicemailLeft   Boolean?
  smsSent         Boolean?
  emailSent       Boolean?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([candidateId])
}

model Client {
  id               String   @id @default(uuid())
  name             String
  industry         String?
  funding          String?
  companySize      String?
  logoUrl          String?
  website          String?
  description      String?  @db.Text
  linkedinUrl      String?
  linkedinId       String?
  companyLogoCdnUrl String?
  employeeCount    Int?
  foundedYear      Int?
  headquarters     String?
  specialties      Json?
  domain           String?
  brandColor       String?
  tagline          String?
  regions          String[]  @default([])

  roles            Role[]
  jobs             Job[]
  recruiters       Recruiter[]
  interviewTemplates InterviewTemplate[]
  teamInvitations  TeamInvitation[]
  interviews       Interview[]
  retentionPolicy  RetentionPolicy?
  ssoConfig        SSOConfig?
  hmMemberships    HiringManagerMembership[]
  webhookEndpoints WebhookEndpoint[]
  governancePolicy GovernancePolicy?
  atsIntegrations  ATSIntegration[]
  // Cost governance
  monthlyAiBudgetUsd Float?  // Per-company monthly AI budget cap (USD)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// Explicit membership linking hiring managers to companies
// Replaces fragile email-domain matching with explicit, auditable access grants
// AI model usage tracking for cost governance and analytics
model AIUsageLog {
  id            String   @id @default(uuid())
  interviewId   String?
  operation     String   // "plan_generation" | "report_generation" | "live_interview" | "text_interview"
  model         String   // e.g. "gemini-1.5-pro", "gemini-2.0-flash-live"
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  durationMs    Int      @default(0) // wall-clock time
  estimatedCost Float    @default(0) // USD estimate
  companyId     String?
  recruiterId   String?
  metadata      Json?    // additional context
  createdAt     DateTime @default(now())

  @@index([interviewId])
  @@index([companyId])
  @@index([createdAt])
  @@index([operation])
}

// Interview quality signals for adaptive questioning validation
model InterviewQualityMetrics {
  id                  String   @id @default(uuid())
  interviewId         String   @unique
  totalQuestions      Int      @default(0)
  followUpQuestions   Int      @default(0) // questions that probed deeper
  avgResponseDepth    Float?   // average word count of candidate responses
  topicTransitions    Int      @default(0) // number of topic changes
  adaptiveDifficulty  Json?    // [{questionIndex, difficulty}] tracking difficulty changes
  coveragePercentage  Float?   // % of planned sections covered
  timeUtilization     Float?   // actual duration / planned duration
  depthScore          Float?   // 0-100 composite depth metric
  personalizationScore Float?  // 0-100 how personalized to the candidate
  createdAt           DateTime @default(now())

  @@index([interviewId])
}

model HiringManagerMembership {
  id        String   @id @default(uuid())
  userId    String   // Supabase user ID of the hiring manager
  email     String   // HM email for reference
  companyId String
  company   Client   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  role      String   @default("viewer") // viewer | collaborator
  grantedBy String?  // admin/recruiter who granted access
  grantedAt DateTime @default(now())
  expiresAt DateTime?
  isActive  Boolean  @default(true)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
  @@index([email])
}

model Role {
  id              String   @id @default(uuid())
  title           String
  location        String?
  salaryRange     String?
  skillsRequired  Json     @default("[]")
  description     String   @db.Text
  experienceYears String?
  clientId        String
  client          Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  embedding       Json?
  matches         Match[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([clientId])
}

model Match {
  id                   String    @id @default(uuid())
  candidateId          String
  candidate            Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  roleId               String
  role                 Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  jobId                String?
  job                  Job?      @relation(fields: [jobId], references: [id], onDelete: SetNull)
  fitScore             Float
  skillMatchScore      Float?
  experienceMatchScore Float?
  reasoning            String?   @db.Text
  status               String?   @default("pending") // pending, reviewed, shortlisted, rejected
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@unique([candidateId, roleId])
  @@index([candidateId])
  @@index([roleId])
  @@index([jobId])
  @@index([fitScore])
}

// ============================================
// Job Management System
// ============================================

model Job {
  id              String         @id @default(uuid())
  title           String
  description     String         @db.Text
  location        String?
  department      String?
  industry        String?
  status          JobStatus      @default(DRAFT)
  employmentType  EmploymentType @default(FULL_TIME)
  remoteType      RemoteType     @default(ONSITE)
  salaryMin       Float?
  salaryMax       Float?
  salaryCurrency  String?        @default("USD")
  experienceMin   Int?
  experienceMax   Int?
  urgencyLevel    Int?           @default(3) // 1-5, 5 = most urgent
  skillsRequired  Json           @default("[]")
  embedding       Json?
  postedAt        DateTime?
  closesAt        DateTime?

  // Relations
  recruiterId     String
  recruiter       Recruiter      @relation(fields: [recruiterId], references: [id])
  companyId       String
  company         Client         @relation(fields: [companyId], references: [id])
  templateId      String?
  template        InterviewTemplate? @relation(fields: [templateId], references: [id])

  jobSkills       JobSkill[]
  applications    Application[]
  matches         Match[]
  invitations     InterviewInvitation[]
  interviews      Interview[]

  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([recruiterId])
  @@index([companyId])
  @@index([status])
  @@index([employmentType])
  @@index([remoteType])
  @@index([postedAt])
}

model JobSkill {
  id            String          @id @default(uuid())
  jobId         String
  job           Job             @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skillName     String
  skillCategory String?
  importance    SkillImportance @default(REQUIRED)
  minYears      Int?
  createdAt     DateTime        @default(now())

  @@unique([jobId, skillName])
  @@index([jobId])
  @@index([skillName])
}

// ============================================
// Application System
// ============================================

model Application {
  id             String            @id @default(uuid())
  candidateId    String
  candidate      Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobId          String
  job            Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  status         ApplicationStatus @default(APPLIED)
  appliedAt      DateTime          @default(now())
  source         String?           // organic, invited, imported, referral
  coverLetterUrl String?
  notes          String?           @db.Text
  reviewedAt     DateTime?
  reviewedBy     String?

  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([candidateId, jobId])
  @@index([candidateId])
  @@index([jobId])
  @@index([status])
  @@index([appliedAt])
}

// ============================================
// Aria AI Interview System
// ============================================

model Interview {
  id              String            @id @default(uuid())
  candidateId     String
  candidate       Candidate         @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  scheduledBy     String
  recruiter       Recruiter         @relation("ScheduledByRecruiter", fields: [scheduledBy], references: [id])
  jobId           String?
  job             Job?              @relation(fields: [jobId], references: [id], onDelete: SetNull)
  templateId      String?
  template        InterviewTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  invitationId    String?           @unique
  invitation      InterviewInvitation? @relation(fields: [invitationId], references: [id], onDelete: SetNull)
  status          InterviewStatus   @default(PENDING)
  type            InterviewType     @default(TECHNICAL)
  mode            InterviewMode     @default(GENERAL_PROFILE)
  duration        Int?              // duration in seconds
  startedAt       DateTime?
  completedAt     DateTime?

  // Interview session data
  transcript      Json?             // [{role, content, timestamp}]
  videoUrl        String?           // Future: webcam recording URL
  audioUrl        String?           // Future: audio recording URL

  // Continuous memory pipeline
  knowledgeGraph          Json?             // Ongoing assembled semantic memory graph
  knowledgeGraphUpdatedAt DateTime?         // Last time KG was updated (staleness tracking)
  transcripts     InterviewTranscript[] // Full un-truncated postgres transcripts

  // Voice interview fields
  voiceProvider     String?         @default("text-sse") // "gemini-live" | "text-sse"
  language          String          @default("en") // Interview language (ISO 639-1)
  recordingUrl      String?         // R2 signed URL for video/audio recording
  recordingFormat   String?         @default("webm")
  recordingSize     Int?            // bytes
  interviewPlan     Json?           // Generated adaptive plan from interview-planner
  skillModuleScores Json?           // Per-module scores [{module, score, details}]
  isPractice        Boolean         @default(false)

  // Composite score (denormalized from report)
  overallScore        Float?
  reportStatus        String?       @default("pending") // "pending" | "generating" | "completed" | "failed"
  reportRetryCount    Int           @default(0)

  // Candidate access (unauthenticated interview room)
  accessToken          String?           @unique
  accessTokenExpiresAt DateTime?
  invitedEmail         String?

  // Proctoring events collected during interview
  integrityEvents Json?             // [{type, description, timestamp}]

  // Recording consent (compliance)
  consentRecording    Boolean       @default(false)
  consentProctoring   Boolean       @default(false)
  consentPrivacy      Boolean       @default(false)
  consentedAt         DateTime?

  // Versioning (audit trail)
  interviewPlanVersion String?      // SHA-256 hash of the generated plan

  // Screen share recording (RESERVED — not yet implemented; tracked for future release)
  screenRecordingUrl  String?
  screenRecordingSize Int?

  // Template snapshot (immutable at interview creation for audit trail)
  templateSnapshot     Json?         // Frozen template+modules config
  templateSnapshotHash String?       // SHA-256 of snapshot

  // Recording pipeline state machine
  recordingState       RecordingState?
  recordingManifestHash String?      // SHA-256 of chunk manifest for integrity

  // Voice session reconnect (durable sessions)
  reconnectToken       String?       @unique

  // Accessibility accommodations
  accommodations       Json?         // {extendedTime, textOnly, captioning, screenReader}

  // Retake tracking
  retakeOfInterviewId  String?       // Links retake to original interview

  // Browser readiness
  readinessVerified    Boolean       @default(false)

  // Multi-tenant
  companyId           String?
  company             Client?       @relation(fields: [companyId], references: [id], onDelete: SetNull)

  // Hypothesis-driven interview (Phase 1)
  recruiterObjectives Json?         // [{text, priority}] — strategic objectives from recruiter
  hmNotes             Json?         // Hiring manager notes visible only to AI
  candidateSelfAssessment Json?     // Post-interview self-assessment responses
  coverageMap         Json?         // Per-section coverage percentages
  evidenceBundle      Json?         // Compiled evidence bundle for recruiter

  // Pause tracking
  pausedAt              DateTime?
  totalPauseDurationMs  Int       @default(0)

  // Legal hold — prevents retention enforcement from deleting data
  legalHold        Boolean   @default(false)
  legalHoldReason  String?
  legalHoldSetBy   String?
  legalHoldSetAt   DateTime?

  // Detailed report (1:1)
  report          InterviewReport?

  // Structured responses and feedback
  responses       InterviewResponse[]
  feedback        InterviewFeedback[]
  proctoringEvents ProctoringEvent[]
  reviewDecisions  ReviewDecision[]

  // Hypothesis & section tracking
  hypotheses      InterviewHypothesis[]
  facts           InterviewFact[]       // Tier 1: Extracted facts
  sections        InterviewSection[]

  // First-class evidence bundle
  evidenceBundleRecord EvidenceBundle?
  // Interviewer state snapshots
  stateSnapshots  InterviewerStateSnapshot[]
  // Replay-grade event timeline
  events          InterviewEvent[]
  // Screen capture sessions
  screenCaptures  ScreenCaptureSession[]
  // N4: In-flight turn fragment persistence
  turnFragments           TurnFragment[]
  // N7: Durable commitments/contradictions (canonical Postgres store)
  interviewCommitments    InterviewCommitment[]
  interviewContradictions InterviewContradiction[]

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([candidateId])
  @@index([scheduledBy])
  @@index([status])
  @@index([jobId])
  @@index([mode])
  @@index([reconnectToken])
  @@index([completedAt])
  @@index([companyId])
}

// ============================================
// Scalable Transcript Storage
// ============================================

// Tier 0: Lossless turn log — canonical conversation ledger
// Every utterance stored with immutable turn IDs. Never truncated, never summarized.
model InterviewTranscript {
  id                  String    @id @default(uuid())
  interviewId         String
  interview           Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  role                String    // 'interviewer' | 'candidate'
  content             String    @db.Text
  turnIndex           Int       // Monotonic ordering within interview
  turnId              String    @default(uuid()) // Immutable UUID per turn for causal linking
  causalParentTurnId  String?   // Links follow-ups to the turn they respond to
  generationMetadata  Json?     // AI turns: { model, promptHash, latencyMs }
  checkpointVersion   Int       @default(0) // Monotonic, incremented per checkpoint batch
  timestamp           DateTime  @default(now())
  serverReceivedAt    DateTime  @default(now()) // When server persisted this turn
  clientTimestamp      DateTime? // Original client-side timestamp
  contentChecksum     String?   // SHA-256 of role:content for integrity verification
  finalized           Boolean   @default(true)
  memoryChecksum      String?   // N5: SHA-256 memory integrity checksum per turn
  sequenceNumber      Int?      // N9: Client-assigned monotonic sequence number

  createdAt           DateTime  @default(now())

  @@unique([interviewId, turnIndex])
  @@unique([interviewId, turnId])
  @@index([interviewId])
}

// ============================================
// Turn Fragments — In-flight partial turn persistence (N4)
// ============================================

model TurnFragment {
  id              String    @id @default(cuid())
  interviewId     String
  interview       Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  chunkId         String    // Unique per in-progress turn
  partialContent  String    @db.Text
  role            String
  startedAt       DateTime  @default(now())
  interruptedAt   DateTime?
  resumedAt       DateTime?
  status          String    @default("in_progress") // in_progress | interrupted | resumed | finalized

  @@unique([interviewId, chunkId])
  @@index([interviewId, status])
}

// ============================================
// Interview Commitments — Durable Postgres store (N7)
// ============================================

model InterviewCommitment {
  id            String    @id @default(cuid())
  interviewId   String
  interview     Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  turnId        String
  description   String    @db.Text
  status        String    @default("pending") // pending | fulfilled | expired
  createdAt     DateTime  @default(now())
  resolvedAt    DateTime?

  @@index([interviewId])
}

// ============================================
// Interview Contradictions — Durable Postgres store (N7)
// ============================================

model InterviewContradiction {
  id              String   @id @default(cuid())
  interviewId     String
  interview       Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  claimTurnId     String
  evidenceTurnId  String
  description     String   @db.Text
  type            String   // temporal | numeric | entity_scope
  confidence      Float
  detectedAt      DateTime @default(now())

  @@index([interviewId])
}

// ============================================
// Interviewer State Snapshots — Deterministic state machine checkpoints
// ============================================

model InterviewerStateSnapshot {
  id            String   @id @default(uuid())
  interviewId   String
  interview     Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  turnIndex     Int      // Ledger turnIndex at which this snapshot was taken
  stateJson     String   @db.Text // Serialized InterviewerState
  stateHash     String   // SHA-256 hash for reconciliation
  createdAt     DateTime @default(now())

  @@unique([interviewId, turnIndex])
  @@index([interviewId])
}

// ============================================
// Interview Event Timeline — Replay-grade observability
// ============================================

model InterviewEvent {
  id            String   @id @default(uuid())
  interviewId   String
  interview     Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  eventType     String   // connect, disconnect, reconnect, checkpoint, grounding_failure, etc.
  payload       Json?    // Event-specific data
  turnIndex     Int?     // Nullable — not all events correlate to a specific turn
  causalEventId String?  // References another InterviewEvent.id that caused this event
  timestamp     DateTime @default(now())

  @@index([interviewId, timestamp])
  @@index([interviewId, eventType])
}

// ============================================
// Evidence Bundle — Canonical Audit Artifact
// ============================================

model EvidenceBundle {
  id                String    @id @default(uuid())
  interviewId       String    @unique
  interview         Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  version           String    @default("1.0")
  compiledAt        DateTime
  artifactManifest  Json      // Links to transcript, recording, plan
  scores            Json      // All dimension scores
  evidenceItems     Json      // Highlights, risk signals, hypothesis outcomes
  versioning        Json      // Scorer model, prompt, rubric versions
  consent           Json?     // Consent state at time of compilation
  integrityHash     String    // SHA-256 of entire bundle
  exportedAt        DateTime?
  exportFormat      String?   // "pdf" | "json"
  legalHold         Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model ScreenCaptureSession {
  id              String    @id @default(uuid())
  interviewId     String
  interview       Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  captureType     String    @default("screen_share") // "screen_share" | "application_window"
  startedAt       DateTime  @default(now())
  endedAt         DateTime?
  thumbnailUrls   Json?     // Periodic screenshot URLs
  recordingUrl    String?   // R2 URL for screen recording
  recordingSize   Int?
  consentGiven    Boolean   @default(false)
  status          String    @default("active") // active, paused, ended, failed
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([interviewId])
}

model InterviewReport {
  id              String    @id @default(uuid())
  interviewId     String    @unique
  interview       Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)

  // Per-skill ratings (micro1-style)
  // [{skill: string, rating: 0-10, description: string, evidence: string}]
  technicalSkills Json

  // Soft skills assessment
  // [{skill: string, rating: 0-10, description: string}]
  softSkills      Json

  // Dimension scores (mercor-style, 0-100)
  domainExpertise     Float?
  clarityStructure    Float?
  problemSolving      Float?
  communicationScore  Float?
  measurableImpact    Float?

  // AI-generated narrative
  summary         String    @db.Text   // Executive summary for recruiters
  strengths       Json                 // [string]
  areasToImprove  Json                 // [string]
  recommendation  String?              // STRONG_YES | YES | MAYBE | NO | STRONG_NO
  hiringAdvice    String?   @db.Text   // Detailed guidance for recruiter

  // Composite score (denormalized from Gemini analysis)
  overallScore    Float?

  // Enhanced dimension scores (Phase 1)
  professionalExperience Float?  // 0-100
  roleFit                Float?  // 0-100 (for JOB_FIT/HYBRID modes)
  culturalFit            Float?  // 0-100
  thinkingJudgment       Float?  // 0-100

  // Evidence & confidence (Phase 1)
  confidenceLevel        String? // HIGH/MEDIUM/LOW
  confidenceIntervals    Json?   // { [dimension]: { low: number, high: number } }
  headline               String? // One-line summary for recruiter quick scan
  riskSignals            Json?   // [{type, severity, evidence, confidence}]
  hypothesisOutcomes     Json?   // [{hypothesis, outcome, evidence}]
  evidenceHighlights     Json?   // [{type, summary, transcriptRange, mediaTimestamp}]
  qaScore                Float?  // Quality assurance score for this report
  qaScoreDetails         Json?   // Detailed QA breakdown (dimensions, flags, etc.)
  rubricSnapshot         Json?   // Frozen rubric used for scoring (audit)

  // Job-fit addendum (JOB_FIT/HYBRID modes)
  jobMatchScore          Float?  // 0-100
  requirementMatches     Json?   // [{skillName, importance, matchLevel, evidence}]
  environmentFitNotes    String? @db.Text

  // Candidate self-assessment
  candidateSelfAssessment Json?

  // Integrity / proctoring
  integrityScore  Float?
  integrityFlags  Json?               // [{type, description, timestamp}]

  // Model/rubric versioning (audit trail)
  scorerModelVersion  String?   // e.g. "gemini-1.5-pro-001"
  scorerPromptVersion String?   // SHA-256 hash of scoring prompt
  rubricVersion       String?   // SHA-256 hash of rubric JSON used
  evidenceHash        String?   // SHA-256 hash of transcript+report+recording for tamper detection

  // Continuity diagnostics (Fix 10: recruiter-facing confidence labels)
  continuityGrade        String?   // GREEN | YELLOW | RED
  continuityIncidents    Json?     // Array of {timestamp, type, detail, severity}
  memoryConfidenceMin    Float?    // Minimum memory confidence observed during interview

  // Human review governance
  reviewStatus    ReviewStatus @default(PENDING_REVIEW)
  reviewedAt      DateTime?
  reviewedBy      String?     // Recruiter/admin ID who reviewed

  // Shareable report link (F2)
  shareToken      String?   @unique
  shareExpiresAt  DateTime?
  recipientEmail  String?   // Who the report was shared with
  sharePurpose    String?   // Reason for sharing
  shareScopes     Json?     // Allowed data scopes: ["scores", "summary", "strengths", ...]
  shareRevoked    Boolean   @default(false)

  // Memory diagnostics (enterprise audit)
  memoryMetadata  Json?     // {memoryConfidence, retrievalStatus, factCount, turnsCount, ...}
  memoryIntegrityScorecard Json? // {verdict, overallGrade, confidence, dimensions, alerts, recommendation}

  // Relations
  views           ReportShareView[]

  createdAt       DateTime  @default(now())

  @@index([reviewStatus, createdAt])
}

// ============================================
// Interview Templates & Invitations
// ============================================

model InterviewTemplate {
  id              String    @id @default(uuid())
  name            String
  description     String?   @db.Text
  roleType        String?   // e.g. "Software Engineer", "Electrician"
  durationMinutes Int       @default(30)
  questions       Json      @default("[]") // [{text, type, category, followUpDepth}]
  aiConfig        Json      @default("{}") // {personality, followUpDepth, language, antiCheatLevel}
  isDefault       Boolean   @default(false)
  status          TemplateStatus @default(DRAFT)

  // Interview mode (Phase 1)
  mode                    InterviewMode @default(GENERAL_PROFILE)
  strategicObjectives     Json?    // [{objective, priority}] — what recruiter wants AI to look for
  customScreeningQuestions Json?   // [{text, mandatory, category}] — fixed questions AI must ask
  hmNotesTemplate         String?  @db.Text  // Template for HM notes
  scoringWeights          Json?    // {dimension: weight} overrides default weights
  maxDurationMinutes      Int      @default(45)
  minDurationMinutes      Int      @default(15)

  // Candidate report visibility policy
  candidateReportPolicy Json?  // {showTranscript, showScores, showStrengths, showAreasToImprove}
  // Retake governance
  retakePolicy    Json?        // {allowed, cooldownDays, maxRetakes}
  // Pre-interview readiness check requirement
  readinessCheckRequired Boolean @default(false)
  // Screen share requirement
  screenShareRequired    Boolean @default(false)
  // Conversational intelligence tuning
  maxTopicDepth          Int     @default(3) // Max follow-up depth per topic (default 3, up to 5 for deep dives)

  // Approval workflow
  approvedBy      String?       // userId of the admin who approved
  approvedAt      DateTime?     // when the template was approved
  approvalNotes   String?  @db.Text  // notes from the approver
  version         Int      @default(1) // template version number

  recruiterId     String?
  recruiter       Recruiter? @relation(fields: [recruiterId], references: [id])
  companyId       String?
  company         Client?   @relation(fields: [companyId], references: [id])

  // Shadow testing and deprecation
  isShadow            Boolean   @default(false) // Shadow mode: generates reports but hides from recruiters
  deprecatedAt        DateTime?
  deprecationReason   String?   @db.Text

  jobs            Job[]
  interviews      Interview[]
  invitations     InterviewInvitation[]
  skillModules    InterviewTemplateModule[]
  versions        InterviewTemplateVersion[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([recruiterId])
  @@index([companyId])
}

model InterviewTemplateVersion {
  id              String    @id @default(uuid())
  templateId      String
  template        InterviewTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  version         Int
  snapshot        Json      // Full template config snapshot at this version
  changeNotes     String?   @db.Text
  promotedBy      String?   // userId who promoted this version
  promotedAt      DateTime  @default(now())
  isShadow        Boolean   @default(false) // Shadow testing version
  isActive        Boolean   @default(false) // Currently active version
  createdAt       DateTime  @default(now())

  @@unique([templateId, version])
  @@index([templateId])
}

// ============================================
// Skill Modules (Micro1-style reusable assessment modules)
// ============================================

model SkillModule {
  id          String   @id @default(cuid())
  name        String                        // e.g. "System Design", "Leadership"
  category    String                        // "technical", "behavioral", "domain"
  duration    Int      @default(5)          // minutes per module
  rubric      Json     @default("{}")       // scoring criteria per level
  prompts     Json     @default("[]")       // base question patterns
  difficulty  String   @default("mid")      // "junior", "mid", "senior", "staff"
  isGlobal    Boolean  @default(true)       // false = tenant-specific
  recruiterId String?
  recruiter   Recruiter? @relation(fields: [recruiterId], references: [id])
  templates   InterviewTemplateModule[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([recruiterId])
}

model InterviewTemplateModule {
  id          String            @id @default(cuid())
  templateId  String
  moduleId    String
  order       Int               @default(0)
  template    InterviewTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  module      SkillModule       @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())

  @@unique([templateId, moduleId])
  @@index([templateId])
  @@index([moduleId])
}

model InterviewInvitation {
  id              String           @id @default(uuid())
  recruiterId     String
  recruiter       Recruiter        @relation(fields: [recruiterId], references: [id])
  candidateId     String?
  candidate       Candidate?       @relation(fields: [candidateId], references: [id])
  jobId           String?
  job             Job?             @relation(fields: [jobId], references: [id])
  templateId      String?
  template        InterviewTemplate? @relation(fields: [templateId], references: [id])
  token           String           @unique
  status          InvitationStatus @default(PENDING)
  sentAt          DateTime?
  deliveredAt     DateTime?
  expiresAt       DateTime
  openedAt        DateTime?
  acceptedAt      DateTime?
  completedAt     DateTime?
  revokedAt       DateTime?
  revokedBy       String?
  reminderCount   Int              @default(0)
  lastReminderAt  DateTime?
  email           String?          // for passive profile invitations

  interview       Interview?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([recruiterId])
  @@index([candidateId])
  @@index([jobId])
  @@index([status])
  @@index([token])
}

// ============================================
// Structured Interview Data
// ============================================

model InterviewResponse {
  id                  String    @id @default(uuid())
  interviewId         String
  interview           Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  questionIndex       Int
  questionText        String    @db.Text
  responseTranscript  String?   @db.Text
  videoUrl            String?
  startTime           DateTime?
  endTime             DateTime?
  aiScore             Float?
  aiFeedback          String?   @db.Text
  skillsDemonstrated  Json?     @default("[]") // [string]

  // Enhanced evidence capture (Phase 1)
  answerQuality       Int?      // 1-5 micro-score per response
  evidenceStrength    Int?      // 1-5 how concrete/verifiable
  flags               Json?     // [{type, description}] — contradictions, vagueness, buzzwords
  hypothesesTested    Json?     // Which hypotheses this answer tested
  mediaTimestampStartMs Int?    // Recording offset for click-to-play
  mediaTimestampEndMs   Int?    // Recording offset end
  sectionName         String?   // Which interview section this belongs to
  difficultyLevel     String?   // Difficulty when question was asked

  createdAt           DateTime  @default(now())

  @@index([interviewId])
}

model InterviewFeedback {
  id            String    @id @default(uuid())
  interviewId   String
  interview     Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  category      String    // e.g. "Technical Skills", "Communication", "Problem Solving"
  score         Float
  narrative     String?   @db.Text
  strengths     Json?     @default("[]") // [string]
  improvements  Json?     @default("[]") // [string]

  createdAt     DateTime  @default(now())

  @@index([interviewId])
}

model ProctoringEvent {
  id          String                   @id @default(uuid())
  interviewId String
  interview   Interview                @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  eventType   String                   // tab_switch, webcam_disabled, clipboard_paste, fullscreen_exit, etc.
  timestamp   DateTime                 @default(now())
  details     Json?                    // Additional context
  severity    ProctoringEventSeverity  @default(LOW)

  @@index([interviewId])
  @@index([eventType])
}

// ============================================
// Hypothesis-Driven Interview (Phase 1)
// ============================================

// Tier 2: Versioned hypotheses — behavioral signals that evolve during interview
model InterviewHypothesis {
  id               String    @id @default(uuid())
  interviewId      String
  interview        Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  hypothesis       String    @db.Text     // e.g. "React experience may be limited to recent roles"
  source           String                 // "resume_analysis", "skill_gap", "career_pattern", "recruiter_objective"
  outcome          String?                // "confirmed", "refuted", "inconclusive"
  evidence         String?   @db.Text     // Evidence supporting the outcome
  confidenceLevel  String?                // HIGH/MEDIUM/LOW
  version          Int       @default(1)  // Monotonic version — incremented on revision
  supersededById   String?                // Points to the newer version if revised
  supportingFactIds String[]              // References to InterviewFact IDs that support this
  createdAt        DateTime  @default(now())

  @@index([interviewId])
}

// Tier 1: Extracted facts — structured claims from candidate responses
// Populated during checkpoint (immediate extraction) and by Inngest (LLM extraction)
model InterviewFact {
  id            String   @id @default(uuid())
  interviewId   String
  interview     Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  turnId        String   // FK to InterviewTranscript.turnId (which turn produced this fact)
  factType      String   // CLAIM, METRIC, DATE, COMPANY, RESPONSIBILITY, TECHNICAL_SKILL
  content       String   @db.Text // The extracted fact text
  confidence    Float    @default(1.0) // 0-1 confidence score
  extractedAt   DateTime @default(now())
  extractedBy   String   // "immediate" | "llm:gemini-2.5-flash" | model identifier

  @@index([interviewId, factType])
  @@index([interviewId])
}

model InterviewSection {
  id              String    @id @default(uuid())
  interviewId     String
  interview       Interview @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  sectionName     String                 // e.g. "Career Arc Exploration", "Skills Verification"
  sectionOrder    Int
  skillModuleName String?                // Which skill module, if any
  plannedDuration Int                    // minutes
  actualDuration  Int?                   // minutes (filled after section completes)
  coverageScore   Float?                 // 0-100 (how well was this section covered)
  evidenceSufficiency String?            // SUFFICIENT | INSUFFICIENT | PARTIAL
  objectivesCovered   Json?              // [{objective, covered: bool, evidenceSnippet}]
  startedAt       DateTime?
  endedAt         DateTime?
  questionsAsked  Int       @default(0)

  @@index([interviewId])
}

// ============================================
// Passive Profiles & Candidate Import
// ============================================

model PassiveProfile {
  id                 String               @id @default(uuid())
  email              String?
  linkedinUrl        String?
  firstName          String?
  lastName           String?
  phone              String?
  currentTitle       String?
  currentCompany     String?
  yearsExperience    Int?
  skills             String[]             @default([])
  resumeUrl          String?
  notes              String?              @db.Text
  extractedData      Json?                // Parsed LinkedIn/resume data
  source             String?              // linkedin, resume, csv, manual
  status             PassiveProfileStatus @default(CREATED)

  sourceRecruiterId  String?
  sourceRecruiter    Recruiter?           @relation(fields: [sourceRecruiterId], references: [id])
  linkedCandidateId  String?              // Links to Candidate after signup

  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  @@index([email])
  @@index([sourceRecruiterId])
  @@index([status])
}

// ============================================
// Notifications
// ============================================

model Notification {
  id          String           @id @default(uuid())
  userId      String           // Can be recruiter or candidate supabase user ID
  candidateId String?
  candidate   Candidate?       @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  type        NotificationType @default(SYSTEM)
  title       String
  message     String           @db.Text
  data        Json?            // Additional context (e.g. jobId, interviewId)
  read        Boolean          @default(false)

  createdAt   DateTime         @default(now())

  @@index([userId])
  @@index([userId, read])
  @@index([type])
  @@index([createdAt])
}

// ============================================
// Documents & File Management
// ============================================

model Document {
  id          String       @id @default(uuid())
  candidateId String
  candidate   Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  type        DocumentType @default(RESUME)
  fileUrl     String
  filename    String
  mimeType    String?
  fileSize    Int?
  parsedData  Json?        // Extracted text/structured data

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([candidateId])
  @@index([type])
}

// ============================================
// Structured Candidate Data
// ============================================

model CandidateSkill {
  id          String    @id @default(uuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  skillName   String
  category    String?   // e.g. "Programming", "Electrical", "Management"
  proficiency Int?      // 1-5 scale
  yearsExp    Float?
  verified    Boolean   @default(false)
  source      String?   // resume, linkedin, interview, manual

  createdAt   DateTime  @default(now())

  @@unique([candidateId, skillName])
  @@index([candidateId])
  @@index([skillName])
}

model CandidateExperience {
  id          String    @id @default(uuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  company     String
  title       String
  startDate   DateTime?
  endDate     DateTime?
  isCurrent   Boolean   @default(false)
  description String?   @db.Text
  location    String?

  createdAt   DateTime  @default(now())

  @@index([candidateId])
}

model CandidateEducation {
  id          String    @id @default(uuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  institution String
  degree      String?
  field       String?
  startDate   DateTime?
  endDate     DateTime?
  gpa         Float?

  createdAt   DateTime  @default(now())

  @@index([candidateId])
}

model CandidateCertification {
  id           String    @id @default(uuid())
  candidateId  String
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  name         String
  issuingOrg   String?
  issueDate    DateTime?
  expiryDate   DateTime?
  credentialId String?

  createdAt    DateTime  @default(now())

  @@index([candidateId])
}

// ============================================
// Messaging System
// ============================================

enum MessageSenderRole {
  RECRUITER
  CANDIDATE
  SYSTEM
}

model Message {
  id              String            @id @default(uuid())
  conversationId  String
  senderId        String
  senderRole      MessageSenderRole
  recipientId     String
  recipientRole   MessageSenderRole
  content         String            @db.Text
  read            Boolean           @default(false)
  readAt          DateTime?
  attachmentUrl   String?
  attachmentName  String?

  createdAt       DateTime          @default(now())

  @@index([conversationId])
  @@index([senderId])
  @@index([recipientId])
  @@index([conversationId, createdAt])
}

// ============================================
// Activity Log / Audit Trail
// ============================================

model ActivityLog {
  id              String   @id @default(uuid())
  userId          String
  userRole        String
  action          String   // e.g. "application.created", "interview.completed", "candidate.status_changed"
  entityType      String   // e.g. "Application", "Interview", "Candidate"
  entityId        String
  metadata        Json?    // Additional context
  ipAddress       String?
  sessionId       String?  // Supabase session correlation
  requestPath     String?  // API endpoint path
  requestMethod   String?  // HTTP method (GET, POST, etc.)
  responseStatus  Int?     // HTTP response status code
  userAgent       String?  // Browser/client user agent

  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([entityType])
  @@index([action])
  @@index([createdAt])
  @@index([userId, createdAt])
  @@index([entityType, createdAt])
}

// ============================================
// Notification Preferences
// ============================================

model NotificationPreference {
  id                   String   @id @default(uuid())
  userId               String   @unique
  emailNotifications   Boolean  @default(true)
  pushNotifications    Boolean  @default(true)
  interviewInvites     Boolean  @default(true)
  applicationUpdates   Boolean  @default(true)
  matchAlerts          Boolean  @default(true)
  feedbackReady        Boolean  @default(true)
  systemAlerts         Boolean  @default(true)

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

// ============================================
// Job Preferences (Candidate Onboarding)
// ============================================

model JobPreference {
  id                  String               @id @default(uuid())
  candidateId         String               @unique
  candidate           Candidate            @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  jobTypes            String[]             @default([])
  preferredLocations  String[]             @default([])
  remotePreference    RemotePreference     @default(FLEXIBLE)
  salaryMin           Int?
  salaryMax           Int?
  salaryCurrency      String               @default("USD")
  availability        CandidateAvailability @default(IMMEDIATELY)
  willingToRelocate   Boolean              @default(false)
  noticePeriod        String?
  preferredCurrency   String?              @default("USD")
  preferredIndustries String[]             @default([])
  preferredCompanies  String[]             @default([])

  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  @@index([candidateId])
}

// ============================================
// Approval Actions (Admin Approval Queue)
// ============================================

model ApprovalAction {
  id           String    @id @default(uuid())
  candidateId  String
  candidate    Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  action       String    // "approved" | "rejected" | "on_hold"
  reason       String?   @db.Text
  adminUserId  String
  adminEmail   String?
  createdAt    DateTime  @default(now())

  @@index([candidateId])
  @@index([adminUserId])
  @@index([createdAt])
}

// ============================================
// Team Invitations (Recruiter Onboarding)
// ============================================

model TeamInvitation {
  id          String    @id @default(uuid())
  email       String
  name        String?
  role        String    @default("recruiter")
  department  String?
  companyId   String
  company     Client    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedById String
  token       String    @unique @default(uuid())
  status      String    @default("pending")
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([email])
  @@index([companyId])
  @@index([token])
  @@index([status])
}

// ============================================
// Review Decisions (Human Review Governance)
// ============================================

model ReviewDecision {
  id                     String              @id @default(uuid())
  interviewId            String
  interview              Interview           @relation(fields: [interviewId], references: [id], onDelete: Cascade)
  reviewerId             String              // Recruiter/admin who reviewed
  reviewerEmail          String?
  decision               ReviewDecisionType
  overrideReason         String?             @db.Text
  previousRecommendation String?             // What AI said before override
  newRecommendation      String?             // What reviewer decided
  createdAt              DateTime            @default(now())

  @@index([interviewId])
  @@index([reviewerId])
  @@index([createdAt])
}

// ============================================
// Report Share Views (Access Logging)
// ============================================

model ReportShareView {
  id          String          @id @default(uuid())
  reportId    String
  report      InterviewReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  shareToken  String
  viewerIp    String?
  userAgent   String?
  viewedAt    DateTime        @default(now())

  @@index([reportId])
  @@index([shareToken])
}

// ============================================
// Enterprise: Data Retention & SSO
// ============================================

model RetentionPolicy {
  id                String   @id @default(uuid())
  name              String
  recordingDays     Int      @default(90)
  transcriptDays    Int      @default(365)
  candidateDataDays Int      @default(730)
  isDefault         Boolean  @default(false)
  metadata          Json?    // {allowedDomains: string[], maxShareDays: number, ...}
  companyId         String?  @unique
  company           Client?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model SSOConfig {
  id            String   @id @default(uuid())
  companyId     String   @unique
  company       Client   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider      String   // "saml" | "oidc"
  metadataUrl   String?
  entityId      String?  // SAML entity ID
  certificate   String?  @db.Text // SAML X.509 certificate
  domain        String   // email domain for auto-routing
  enabled       Boolean  @default(false)
  // OIDC fields
  clientId      String?  // OIDC client ID
  clientSecret  String?  // OIDC client secret (encrypted at rest via Supabase)
  issuerUrl     String?  // OIDC issuer URL (e.g. https://login.microsoftonline.com/{tenant}/v2.0)
  callbackUrl   String?  // Redirect URL after authentication
  scopes        String   @default("openid profile email") // OIDC scopes
  // SAML fields
  ssoUrl        String?  // SAML SSO endpoint
  sloUrl        String?  // SAML single logout URL
  nameIdFormat  String?  @default("urn:oasis:names:tc:SAML:1.1:nameid-format:emailAddress")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([domain])
}

// ============================================
// Webhook System — External Event Dispatch
// ============================================

model WebhookEndpoint {
  id        String   @id @default(uuid())
  companyId String
  company   Client   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  url       String
  events    Json     @default("[]") // ["interview.completed", "report.ready", "invitation.accepted"]
  secret    String   // HMAC-SHA256 signing key
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@index([companyId, isActive])
}

model WebhookDelivery {
  id         String   @id @default(uuid())
  endpointId String
  endpoint   WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)
  event      String
  payload    Json
  statusCode Int?
  attempts   Int      @default(0)
  lastError  String?  @db.Text
  createdAt  DateTime @default(now())

  @@index([endpointId])
  @@index([event])
}

// ── DSAR (Data Subject Access Request) Deletion Workflow ──────────────

model DataDeletionRequest {
  id                String    @id @default(uuid())
  candidateId       String
  candidate         Candidate @relation(fields: [candidateId], references: [id])
  status            String    @default("PENDING") // PENDING, PROCESSING, COMPLETED, CANCELLED
  requestedAt       DateTime  @default(now())
  gracePeriodEndsAt DateTime
  processedAt       DateTime?
  cancelledAt       DateTime?
  reason            String?
  dataManifest      Json?     // Records what data was deleted
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([candidateId])
  @@index([status])
  @@index([gracePeriodEndsAt])
}

// ── AI Decision Governance Policies ───────────────────────────────────

model GovernancePolicy {
  id                  String   @id @default(uuid())
  companyId           String   @unique
  company             Client   @relation(fields: [companyId], references: [id])
  canOverrideScore    String[] @default(["admin"])
  canRedactTranscript String[] @default(["admin"])
  canSuppressReport   String[] @default(["admin"])
  requireReviewBelow  Float?   // Auto-require human review if AI score below this
  autoPublishAbove    Float?   // Auto-publish reports above this threshold
  activeModelVersion  String?              // Currently active scorer model version
  scoringTemperature  Float    @default(0.15) // LLM temperature for scoring
  modelABTestEnabled  Boolean  @default(false) // Whether A/B testing between model versions is active
  modelABTestSplit    Float    @default(0.0)   // Fraction of traffic routed to challenger model (0.0-1.0)
  enforced            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ============================================
// ATS Integration — External System Connections
// ============================================

model ATSIntegration {
  id            String   @id @default(uuid())
  companyId     String
  company       Client   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  provider      String   // "greenhouse" | "lever" | "workday" | "ashby"
  apiKey        String   // Encrypted API key
  webhookSecret String?  // For webhook signature verification
  baseUrl       String?  // Custom API base URL (for self-hosted)
  config        Json?    // Provider-specific config (field mappings, etc.)
  enabled       Boolean  @default(true)
  lastSyncAt    DateTime?
  syncStatus    String?  // "idle" | "syncing" | "error"
  syncError     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([companyId, provider])
  @@index([companyId])
  @@index([provider])
}
